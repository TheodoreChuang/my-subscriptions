# Copy to .env and fill in from the Google Cloud Console -> APIs & Services ->
# Credentials -> your OAuth 2.0 Client ID (type: Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must EXACTLY match an "Authorized redirect URI" registered on the Web app client.
# (If you instead create a "Desktop app" client, any http://localhost:PORT path is
#  accepted without registration — set this to whatever port is free.)
GOOGLE_REDIRECT_URI=http://localhost:3000/callback

# Which calendar to read. "primary" = the signed-in user's main calendar.
CALENDAR_ID=primary

# How many days of history to attempt to pull (feasibility check).
LOOKBACK_DAYS=30
