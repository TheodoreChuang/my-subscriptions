# Copy to .env and fill in from the WHOOP Developer Dashboard (your app's page).
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Must EXACTLY match a redirect URL registered on the WHOOP app.
WHOOP_REDIRECT_URI=http://localhost:3000/callback

# How many days of history to attempt to pull (feasibility check).
LOOKBACK_DAYS=30
